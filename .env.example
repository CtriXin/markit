# Local API
MARKIT_SERVER_PORT=4317
MARKIT_WEB_ORIGIN=http://127.0.0.1:5173
MARKIT_JSON_LIMIT=90mb

# Optional public project catalog. When absent, Markit keeps direct URL mode enabled.
MARKIT_CATALOG_ROOT=/Users/xin/ptc-wiki

# Optional GitLab submit. auto uses token first, then local glab auth.
MARKIT_GITLAB_BASE_URL=https://gitlab.adsconflux.xyz
MARKIT_GITLAB_AUTH=auto
MARKIT_GITLAB_TOKEN=

# Optional Feishu Base sync after GitLab issue creation.
MARKIT_FEISHU_SYNC=0
MARKIT_FEISHU_AUTH=auto
MARKIT_FEISHU_BASE_URL=https://open.feishu.cn
MARKIT_FEISHU_BASE_TOKEN=I7m2bnPDgaYnwksqp1jcmmW9nOd
MARKIT_FEISHU_TABLE_ID=tbl0yrCubWcpZCvw
MARKIT_FEISHU_ATTACHMENT_FIELD_ID=fldKBwIUX2
MARKIT_FEISHU_OWNER_OPEN_IDS=ou_30c6391467af3f8ffb00e07bac50b368
MARKIT_FEISHU_ACCESS_TOKEN=
MARKIT_FEISHU_CLI_AS=user

# AI normalizer
# off | mock | openai-compatible | local-mms-mmf
MARKIT_AI_PROVIDER=off
MARKIT_MODEL_BASE_URL=
MARKIT_MODEL_API_KEY=
MARKIT_MODEL_ID=
MARKIT_MODEL_MULTIMODAL=false

# Local MMF / MMS. Leave empty to auto-discover ~/.config/mms/generated/model-routes.json.
MARKIT_MMF_CONFIG=
MARKIT_MMF_BASE_URL=
MARKIT_MMF_API_KEY=
MARKIT_MMF_MODEL_ID=
MARKIT_MMF_PREFERRED_MODELS=mimo-v2.5,qwen3.6-plus,qwen3.5-plus,MiniMax-M2.7
MARKIT_MMS_ROUTES_PATH=
MARKIT_MMS_CAPABILITIES_PATH=
